{
    "name": "ceniver/laravel-blog",
    "description": "API-driven multi-language blog package for Laravel with full SEO support",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "blog", "seo", "multi-language", "api"],
    "authors": [
        {
            "name": "Ceniver",
            "email": "info@ceniver.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ceniver\\Blog\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ceniver\\Blog\\BlogServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
